{
  "version": "1.0.0",
  "componentsMap": [
    {
      "package": "@kaiwu-cloud/lowcode-engine-component",
      "version": "3.1.0",
      "exportName": "KaiwuJsx",
      "main": "src/index.tsx",
      "destructuring": true,
      "subName": "",
      "componentName": "KaiwuJsx"
    },
    {
      "package": "@kaiwu-cloud/lowcode-engine-component",
      "version": "3.1.0",
      "exportName": "KaiwuFlexLayout",
      "main": "src/index.tsx",
      "destructuring": true,
      "subName": "",
      "componentName": "KaiwuFlexLayout"
    },
    {
      "devMode": "lowCode",
      "componentName": "Page"
    }
  ],
  "componentsTree": [
    {
      "componentName": "Page",
      "id": "node_dashboard_root",
      "props": {
        "ref": "outerView",
        "style": {
          "width": "100%",
          "height": "100%",
          "backgroundColor": "#f0f2f5"
        }
      },
      "dataSource": {
        "list": [
          {
            "type": "fetch",
            "isInit": true,
            "options": {
              "params": {},
              "method": "GET",
              "isCors": true,
              "timeout": 5000,
              "headers": {},
              "uri": "/mainApi/auth/currentUser"
            },
            "id": "getCurrentUser"
          },
          {
            "type": "fetch",
            "isInit": false,
            "options": {
              "params": {},
              "method": "POST",
              "isCors": true,
              "timeout": 5000,
              "uri": "/mainApi/dashboard/metrics"
            },
            "id": "getMetrics"
          }
        ]
      },
      "children": [
        {
          "componentName": "KaiwuFlexLayout",
          "id": "node_dashboard_layout",
          "props": {
            "style": {
              "padding": "20px",
              "display": "grid",
              "gridTemplateColumns": "repeat(3, 1fr)",
              "gap": "20px"
            }
          },
          "children": [
            {
              "componentName": "KaiwuJsx",
              "id": "node_metric_card_1",
              "props": {
                "render": {
                  "type": "JSFunction",
                  "value": "function() { \n  const { metrics } = this.state;\n  return (\n    <div style={{ background: '#fff', padding: '20px', borderRadius: '8px' }}>\n      <h3>总订单数</h3>\n      <p style={{ fontSize: '24px', fontWeight: 'bold' }}>{metrics.totalOrders}</p>\n    </div>\n  );\n}"
                }
              }
            },
            {
              "componentName": "KaiwuJsx",
              "id": "node_metric_card_2",
              "props": {
                "render": {
                  "type": "JSFunction",
                  "value": "function() { \n  const { metrics } = this.state;\n  return (\n    <div style={{ background: '#fff', padding: '20px', borderRadius: '8px' }}>\n      <h3>已完成订单</h3>\n      <p style={{ fontSize: '24px', fontWeight: 'bold', color: 'green' }}>{metrics.completedOrders}</p>\n    </div>\n  );\n}"
                }
              }
            },
            {
              "componentName": "KaiwuJsx",
              "id": "node_metric_card_3",
              "props": {
                "render": {
                  "type": "JSFunction",
                  "value": "function() { \n  const { metrics } = this.state;\n  return (\n    <div style={{ background: '#fff', padding: '20px', borderRadius: '8px' }}>\n      <h3>不良率</h3>\n      <p style={{ fontSize: '24px', fontWeight: 'bold', color: 'red' }}>{metrics.defectRate}</p>\n    </div>\n  );\n}"
                }
              }
            }
          ]
        },
        {
          "componentName": "KaiwuFlexLayout",
          "id": "node_charts_layout",
          "props": {
            "style": {
              "padding": "0 20px 20px 20px"
            }
          },
          "children": [
            {
              "componentName": "KaiwuJsx",
              "id": "node_main_chart",
              "props": {
                "render": {
                  "type": "JSFunction",
                  "value": "function() { return <div style={{ background: '#fff', height: '400px', borderRadius: '8px', padding: '20px' }}>图表区域占位</div> }"
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
