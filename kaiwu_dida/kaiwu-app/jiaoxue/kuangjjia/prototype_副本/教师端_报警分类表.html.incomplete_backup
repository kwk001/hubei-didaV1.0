<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>报警分类表 - 教师端</title>
    <link rel="stylesheet" href="https://at.alicdn.com/t/c/font_5124072_s39q5gmh59a.css">
    <link rel="stylesheet" href="./common.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            background: #F5F7FA;
            display: flex;
            height: 100vh;
        }

        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .header {
            background: #fff;
            padding: 16px 24px;
            border-bottom: 1px solid #F0F0F0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .breadcrumb {
            font-size: 14px;
            color: #666;
        }

        .logout-btn {
            background: none;
            border: none;
            color: #666;
            cursor: pointer;
            font-size: 14px;
        }

        .content-body {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
            background: #F0F2F5;
        }

        /* 统计卡片 */
        .stats-bar {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 16px;
            margin-bottom: 20px;
        }

        .stat-card {
            background: #fff;
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .stat-icon {
            width: 56px;
            height: 56px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
        }

        .stat-icon.blue { background: linear-gradient(135deg, #E6F7FF 0%, #BAE7FF 100%); }
        .stat-icon.orange { background: linear-gradient(135deg, #FFF7E6 0%, #FFE7BA 100%); }
        .stat-icon.red { background: linear-gradient(135deg, #FFF1F0 0%, #FFCCC7 100%); }
        .stat-icon.green { background: linear-gradient(135deg, #F6FFED 0%, #D9F7BE 100%); }

        .stat-content { flex: 1; }
        .stat-value {
            font-size: 28px;
            font-weight: 700;
            color: #262626;
            margin-bottom: 4px;
        }
        .stat-label {
            font-size: 13px;
            color: #8C8C8C;
        }

        /* 搜索筛选 */
        .search-filter-card {
            background: #fff;
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 20px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        }

        .search-row {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .filter-select, .date-picker {
            padding: 10px 16px;
            border: 1px solid #D9D9D9;
            border-radius: 8px;
            font-size: 14px;
            background: #fff;
            min-width: 140px;
        }

        .btn-search, .btn-export {
            padding: 10px 24px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
        }

        .btn-search {
            background: linear-gradient(135deg, #1890FF 0%, #096DD9 100%);
            color: #fff;
            border: none;
        }

        .btn-export {
            background: #fff;
            border: 1px solid #D9D9D9;
            color: #666;
        }

        /* 图表区域 */
        .charts-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 20px;
        }

        .chart-card {
            background: #fff;
            border-radius: 12px;
            padding: 24px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        }

        .chart-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .chart-title {
            font-size: 16px;
            font-weight: 600;
            color: #333;
        }

        .chart-container {
            width: 100%;
            height: 350px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        /* SVG图表样式 */
        .pie-chart-svg, .bar-chart-svg {
            width: 100%;
            height: 100%;
        }

        .pie-slice {
            cursor: pointer;
            transition: all 0.3s;
        }

        .pie-slice:hover {
            opacity: 0.8;
            transform: scale(1.02);
        }

        .pie-label {
            font-size: 12px;
            fill: #333;
            text-anchor: middle;
        }

        .pie-percent {
            font-size: 11px;
            fill: #fff;
            text-anchor: middle;
            font-weight: 600;
        }

        .pie-legend {
            font-size: 12px;
            fill: #666;
        }

        .bar-rect {
            cursor: pointer;
            transition: all 0.3s;
        }

        .bar-rect:hover {
            opacity: 0.8;
        }

        .bar-label {
            font-size: 11px;
            fill: #333;
            text-anchor: end;
        }

        .bar-value {
            font-size: 12px;
            fill: #1890FF;
            font-weight: 600;
        }

        .chart-axis {
            stroke: #D9D9D9;
            stroke-width: 1;
        }

        .chart-grid {
            stroke: #F0F0F0;
            stroke-width: 1;
            stroke-dasharray: 4, 4;
        }

        .chart-tooltip {
            position: absolute;
            background: rgba(0,0,0,0.8);
            color: #fff;
            padding: 8px 12px;
            border-radius: 4px;
            font-size: 12px;
            pointer-events: none;
            opacity: 0;
            transition: opacity 0.3s;
            z-index: 100;
        }

        /* 数据表格 */
        .table-card {
            background: #fff;
            border-radius: 12px;
            padding: 24px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        }

        .table-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
        }

        .table-title {
            font-size: 16px;
            font-weight: 600;
            color: #333;
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
        }

        .data-table th {
            background: #FAFAFA;
            padding: 12px 16px;
            text-align: left;
            font-size: 13px;
            font-weight: 600;
            color: #333;
            border-bottom: 2px solid #E8E8E8;
        }

        .data-table td {
            padding: 16px;
            border-bottom: 1px solid #F0F0F0;
            font-size: 14px;
            color: #666;
        }

        .data-table tbody tr:hover {
            background: #F5F7FA;
        }

        /* 报警类型标签 */
        .alarm-type {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 4px;
            font-size: 12px;
            font-weight: 500;
        }

        .alarm-type.mechanical {
            background: #FFF2E8;
            color: #FA541C;
        }

        .alarm-type.electrical {
            background: #E6F7FF;
            color: #1890FF;
        }

        .alarm-type.hydraulic {
            background: #F6FFED;
            color: #52C41A;
        }

        .alarmType.pneumatic {
            background: #FFF7E6;
            color: #FA8C16;
        }

        .alarm-type.thermal {
            background: #FFF1F0;
            color: #F5222D;
        }

        /* 占比显示 */
        .percentage-bar {
            width: 100%;
            height: 8px;
            background: #F0F0F0;
            border-radius: 4px;
            overflow: hidden;
        }

        .percentage-fill {
            height: 100%;
            border-radius: 4px;
            transition: width 0.3s;
        }

        /* 分页 */
        .pagination {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid #F0F0F0;
        }

        .pagination-left {
            font-size: 14px;
            color: #666;
        }

        .pagination-right {
            display: flex;
            gap: 8px;
        }

        .pagination-btn {
            padding: 8px 14px;
            border: 1px solid #D9D9D9;
            background: #fff;
            border-radius: 6px;
            cursor: pointer;
            font-size: 13px;
        }

        .pagination-btn.active {
            background: #1890FF;
            color: #fff;
            border-color: #1890FF;
        }
    </style>
</head>
<body>
    <!-- 侧边栏 -->
    <!-- 导航容器 - 由通用加载器动态加载 -->
    <div id="nav-container"></div>