        function saveQuestion() { alert('保存成功！'); goBack(); }
        function toggleMenu(element) { element.classList.toggle('collapsed'); const menuItems = element.nextElementSibling; if (menuItems && menuItems.classList.contains('menu-items')) { menuItems.classList.toggle('collapsed'); } }
        function logout() { localStorage.removeItem('iBodaoUser'); window.location.href = './教学实训平台_登录.html'; }
