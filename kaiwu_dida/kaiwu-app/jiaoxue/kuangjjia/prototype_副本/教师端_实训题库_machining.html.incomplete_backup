    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif; background: #F5F7FA; display: flex; height: 100vh; }

        .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
        .page-title { font-size: 20px; font-weight: 600; color: #333; }
        .page-title::before { content: '🔧 '; }
        .btn-group { display: flex; gap: 12px; }
        .btn-primary { padding: 10px 24px; background: #1890FF; color: #fff; border: none; border-radius: 4px; cursor: pointer; font-size: 14px; }
        .btn-primary:hover { background: #40A9FF; }
        .btn-secondary { padding: 10px 24px; border: 1px solid #D9D9D9; background: #fff; border-radius: 4px; cursor: pointer; font-size: 14px; color: #666; }
        .btn-secondary:hover { border-color: #1890FF; color: #1890FF; }
        .form-container { background: #fff; border-radius: 8px; padding: 24px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
        .form-section { margin-bottom: 24px; padding-bottom: 24px; border-bottom: 1px solid #F0F0F0; }
        .form-section:last-child { margin-bottom: 0; padding-bottom: 0; border-bottom: none; }
        .section-title { font-size: 16px; font-weight: 600; color: #333; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
        .section-title::before { content: ''; width: 4px; height: 16px; background: #1890FF; border-radius: 2px; }
        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
        .form-item { margin-bottom: 20px; }
        .form-item label { display: block; margin-bottom: 8px; font-size: 14px; color: #333; }
        .form-item label .required { color: #FF4D4F; }
        .form-item input, .form-item select, .form-item textarea { width: 100%; padding: 10px 12px; border: 1px solid #D9D9D9; border-radius: 4px; font-size: 14px; transition: all 0.3s; }
        .form-item input:focus, .form-item select:focus, .form-item textarea:focus { outline: none; border-color: #1890FF; box-shadow: 0 0 0 2px rgba(24,144,255,0.2); }
        .form-item textarea { resize: vertical; min-height: 120px; }
        .checkbox-wrapper { display: flex; align-items: center; gap: 8px; }
        .checkbox-wrapper input[type="checkbox"] { width: auto; }
        .tool-table { width: 100%; border-collapse: collapse; margin-top: 12px; }
        .tool-table th, .tool-table td { padding: 12px; border: 1px solid #E8E8E8; text-align: left; }
        .tool-table th { background: #FAFAFA; font-weight: 600; }
        .tool-table input, .tool-table select { width: 100%; padding: 6px 10px; border: 1px solid #D9D9D9; border-radius: 4px; }
        .add-row-btn { margin-top: 12px; padding: 8px 16px; border: 1px dashed #1890FF; background: #fff; color: #1890FF; border-radius: 4px; cursor: pointer; font-size: 14px; }
        .add-row-btn:hover { background: #E6F7FF; }
    
        /* 菜单图标宽度修复 */
        .menu-item .iconfont {
            width: 20px;
            min-width: 20px;
            text-align: center;
            margin-right: 8px;
            font-size: 16px;
            display: inline-block;
            flex-shrink: 0;
        }
        
    </style>
