    <script>
        function addToolRow() { const tbody = document.getElementById('toolTableBody'); const row = document.createElement('tr'); row.innerHTML = '<td><input type="text" placeholder="刀号"></td><td><input type="text" placeholder="刀具名称"></td><td><input type="text" placeholder="规格"></td><td><input type="text" placeholder="加工内容"></td>'; tbody.appendChild(row); }
