<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>设备状态分析 - 教师端</title>
    <link rel="stylesheet" href="https://at.alicdn.com/t/c/font_5124072_s39q5gmh59a.css">
    <link rel="stylesheet" href="./common.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            background: #F5F7FA;
            display: flex;
            height: 100vh;
        }

        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .header {
            background: #fff;
            padding: 16px 24px;
            border-bottom: 1px solid #F0F0F0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .breadcrumb {
            font-size: 14px;
            color: #666;
        }

        .logout-btn {
            background: none;
            border: none;
            color: #666;
            cursor: pointer;
            font-size: 14px;
        }

        .content-body {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
            background: #F0F2F5;
        }

        /* 标签页 */
        .tabs-container {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
            overflow: hidden;
        }

        .tabs-header {
            display: flex;
            border-bottom: 1px solid #F0F0F0;
            background: #FAFAFA;
        }

        .tab-item {
            padding: 16px 32px;
            cursor: pointer;
            font-size: 14px;
            color: #666;
            border-bottom: 2px solid transparent;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .tab-item:hover {
            color: #1890FF;
            background: #F0F7FF;
        }

        .tab-item.active {
            color: #1890FF;
            border-bottom-color: #1890FF;
            background: #fff;
            font-weight: 500;
        }

        .tab-content {
            display: none;
            padding: 24px;
        }

        .tab-content.active {
            display: block;
        }

        /* 搜索筛选 */
        .search-filter {
            display: flex;
            gap: 12px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .search-input, .filter-select, .date-picker {
            padding: 10px 16px;
            border: 1px solid #D9D9D9;
            border-radius: 8px;
            font-size: 14px;
        }

        .search-input {
            flex: 1;
            min-width: 200px;
        }

        .filter-select, .date-picker {
            min-width: 140px;
        }

        .btn-search, .btn-export {
            padding: 10px 24px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
        }

        .btn-search {
            background: linear-gradient(135deg, #1890FF 0%, #096DD9 100%);
            color: #fff;
            border: none;
        }

        .btn-export {
            background: #fff;
            border: 1px solid #D9D9D9;
            color: #666;
        }

        /* 图表容器 */
        .chart-container {
            background: #fff;
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 20px;
            border: 1px solid #F0F0F0;
        }

        .chart-title {
            font-size: 16px;
            font-weight: 600;
            color: #333;
            margin-bottom: 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .chart-area {
            width: 100%;
            height: 400px;
            background: #FAFAFA;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #999;
        }

        /* 设备用时分析图表 */
        .device-time-chart, .device-compare-chart {
            width: 100%;
            height: 400px;
            padding: 20px;
        }

        .time-chart-svg, .compare-chart-svg {
            width: 100%;
            height: 100%;
        }

        .chart-bar {
            fill: url(#barGradient);
            rx: 4;
            transition: all 0.3s;
        }

        .chart-bar:hover {
            fill: #40A9FF;
        }

        .chart-line {
            fill: none;
            stroke: #1890FF;
            stroke-width: 3;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .chart-point {
            fill: #1890FF;
            stroke: #fff;
            stroke-width: 2;
            cursor: pointer;
            transition: all 0.3s;
        }

        .chart-point:hover {
            r: 8;
            fill: #52C41A;
        }

        .chart-axis {
            stroke: #D9D9D9;
            stroke-width: 1;
        }

        .chart-grid {
            stroke: #F0F0F0;
            stroke-width: 1;
            stroke-dasharray: 4, 4;
        }

        .chart-text {
            fill: #666;
            font-size: 12px;
            text-anchor: middle;
        }

        .chart-text.y-axis {
            text-anchor: end;
        }

        .chart-label {
            fill: #333;
            font-size: 11px;
            text-anchor: middle;
        }

        .chart-value {
            fill: #1890FF;
            font-size: 12px;
            font-weight: 600;
            text-anchor: middle;
        }

        .compare-bar {
            rx: 4;
            transition: all 0.3s;
        }

        .compare-bar:hover {
            opacity: 0.8;
        }

        .device-label {
            fill: #333;
            font-size: 12px;
            text-anchor: end;
        }

        /* 时序图样式 */
        .timeline-chart {
            width: 100%;
            height: 400px;
            overflow-x: auto;
            position: relative;
        }

        .timeline-container {
            min-width: 1200px;
            height: 100%;
            padding: 20px;
        }

        .timeline-row {
            display: flex;
            align-items: center;
            height: 50px;
            margin-bottom: 8px;
            border-bottom: 1px solid #F0F0F0;
        }

        .timeline-label {
            width: 150px;
            font-size: 13px;
            color: #333;
            font-weight: 500;
        }

        .timeline-bar {
            flex: 1;
            height: 30px;
            position: relative;
            background: #F5F5F5;
            border-radius: 4px;
        }

        .timeline-segment {
            position: absolute;
            height: 100%;
            border-radius: 4px;
            cursor: pointer;
            transition: all 0.3s;
        }

        .timeline-segment:hover {
            transform: scaleY(1.1);
            box-shadow: 0 2px 8px rgba(0,0,0,0.2);
        }

        .timeline-segment.running { background: #52C41A; }
        .timeline-segment.idle { background: #FAAD14; }
        .timeline-segment.alarm { background: #FF4D4F; }
        .timeline-segment.offline { background: #999; }
        .timeline-segment.debug { background: #1890FF; }

        /* 数据表格 */
        .data-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        .data-table th {
            background: #FAFAFA;
            padding: 12px 16px;
            text-align: left;
            font-size: 13px;
            font-weight: 600;
            color: #333;
            border-bottom: 2px solid #E8E8E8;
        }

        .data-table td {
            padding: 12px 16px;
            border-bottom: 1px solid #F0F0F0;
            font-size: 14px;
            color: #666;
        }

        .data-table tbody tr:hover {
            background: #F5F7FA;
        }

        /* 统计卡片 */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 16px;
            margin-bottom: 20px;
        }

        .stat-card {
            background: #fff;
            border-radius: 8px;
            padding: 16px;
            border: 1px solid #F0F0F0;
            text-align: center;
        }

        .stat-value {
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 4px;
        }

        .stat-value.running { color: #52C41A; }
        .stat-value.idle { color: #FAAD14; }
        .stat-value.alarm { color: #FF4D4F; }
        .stat-value.offline { color: #999; }
        .stat-value.debug { color: #1890FF; }

        .stat-label {
            font-size: 12px;
            color: #666;
        }

        /* 图例 */
        .legend {
            display: flex;
            gap: 20px;
            margin-bottom: 16px;
            flex-wrap: wrap;
        }

        .legend-item {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            color: #666;
        }

        .legend-color {
            width: 16px;
            height: 16px;
            border-radius: 4px;
        }

        .legend-color.running { background: #52C41A; }
        .legend-color.idle { background: #FAAD14; }
        .legend-color.alarm { background: #FF4D4F; }
        .legend-color.offline { background: #999; }
        .legend-color.debug { background: #1890FF; }

        /* 分页 */
        .pagination {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid #F0F0F0;
        }

        .pagination-left {
            font-size: 14px;
            color: #666;
        }

        .pagination-right {
            display: flex;
            gap: 8px;
        }

        .pagination-btn {
            padding: 8px 14px;
            border: 1px solid #D9D9D9;
            background: #fff;
            border-radius: 6px;
            cursor: pointer;
            font-size: 13px;
        }

        .pagination-btn.active {
            background: #1890FF;
            color: #fff;
            border-color: #1890FF;
        }
    </style>
</head>
<body>
    <!-- 侧边栏 -->
    <!-- 导航容器 - 由通用加载器动态加载 -->
    <div id="nav-container"></div>
    <!-- 导航组件加载器 -->
    <script src="./nav-loader-universal.js" data-nav-type="teacher"></script>
</body>
</html>