    <!-- 主内容区 -->
    <div class="main-content">
        <div class="header">
            <div>首页 / 生产管理 / 生产工单管理</div>
            <div>👤 教师：张老师 | <button class="btn btn-danger" onclick="logout()">退出</button></div>
        </div>
        
        <div class="content">
            <!-- 统计卡片 -->
            <div class="stats-row">
                <div class="stat-card primary">
                    <div class="stat-value" id="totalCount">0</div>
                    <div class="stat-label">总工单数</div>
                </div>
                <div class="stat-card warning">
                    <div class="stat-value" id="pendingCount">0</div>
                    <div class="stat-label">待排产</div>
                </div>
                <div class="stat-card success">
                    <div class="stat-value" id="processingCount">0</div>
                    <div class="stat-label">进行中</div>
                </div>
                <div class="stat-card danger">
                    <div class="stat-value" id="pausedCount">0</div>
                    <div class="stat-label">已暂停</div>
                </div>
                <div class="stat-card purple">
                    <div class="stat-value" id="completedCount">0</div>
                    <div class="stat-label">已完成</div>
                </div>
            </div>
            
            <!-- 筛选栏 -->
            <div class="filter-bar">
                <div class="filter-row">
                    <div class="filter-item">
                        <label>生产工单号</label>
                        <input type="text" id="filterOrderNo" placeholder="请输入工单号">
                    </div>
                    <div class="filter-item">
                        <label>产品名称</label>
                        <input type="text" id="filterProduct" placeholder="请输入产品名称">
                    </div>
                    <div class="filter-item">
                        <label>排产状态</label>
                        <select id="filterStatus">
                            <option value="">全部</option>
                            <option value="pending">待排产</option>
                            <option value="scheduled">已排产</option>
                            <option value="processing">进行中</option>
                            <option value="paused">已暂停</option>
                            <option value="completed">已完成</option>
                        </select>
                    </div>
                    <div class="filter-item">
                        <label>优先级</label>
                        <select id="filterPriority">
                            <option value="">全部</option>
                            <option value="high">高</option>
                            <option value="medium">中</option>
                            <option value="low">低</option>
                        </select>
                    </div>
                    <div class="filter-item">
                        <label>所属专业</label>
                        <select id="filterMajor">
                            <option value="">全部</option>
                            <option value="机械工程">机械工程</option>
                            <option value="数控技术">数控技术</option>
                            <option value="模具设计">模具设计</option>
                            <option value="机电一体化">机电一体化</option>
                        </select>
                    </div>
                    <div class="filter-btns">
                        <button class="btn btn-primary" onclick="searchOrders()">🔍 查询</button>
                        <button class="btn btn-default" onclick="resetFilter()">重置</button>
                    </div>
                </div>
            </div>
            
