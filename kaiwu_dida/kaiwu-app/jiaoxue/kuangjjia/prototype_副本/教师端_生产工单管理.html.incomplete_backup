                    <button class="btn btn-warning" onclick="batchSchedule()">📋 批量排产</button>
                </div>
                <div class="toolbar-right">
                    <button class="btn btn-default" onclick="batchPause()" id="btnBatchPause">⏸️ 批量暂停</button>
                    <button class="btn btn-default" onclick="batchResume()" id="btnBatchResume">▶️ 批量继续</button>
                    <button class="btn btn-danger" onclick="batchComplete()" id="btnBatchComplete">✅ 批量结束</button>
                </div>
            </div>
            
